2-2-2.5 0-.83.42-1.64 1-2.09V6.25c-1.09.53-2 1.84-2 3.25C6 11.31 7.55 13 9 13h4c1.45 0 3-1.69 3-3.5S14.5 6 13 6z\"></path></svg></a>1-3 설치</h2>\n<ul>\n<li>JDK</li>\n<li>JAVA 환경 변수 세팅</li>\n<li>이클립스 EE 다운로드</li>\n<li>마켓플레이스에서 STS 3.x 다운로드</li>\n<li>웹컨테이너 톰캣 설치</li>\n</ul>\n<h3 id=\"참고자료\" style=\"position:relative;\"><a href=\"#%EC%B0%B8%EA%B3%A0%EC%9E%90%EB%A3%8C\" aria-label=\"참고자료 permalink\" class=\"anchor before\"><svg aria-hidden=\"true\" focusable=\"false\" height=\"16\" version=\"1.1\" viewBox=\"0 0 16 16\" width=\"16\"><path fill-rule=\"evenodd\" d=\"M4 9h1v1H4c-1.5 0-3-1.69-3-3.5S2.55 3 4 3h4c1.45 0 3 1.69 3 3.5 0 1.41-.91 2.72-2 3.25V8.59c.58-.45 1-1.27 1-2.09C10 5.22 8.98 4 8 4H4c-.98 0-2 1.22-2 2.5S3 9 4 9zm9-3h-1v1h1c1 0 2 1.22 2 2.5S13.98 12 13 12H9c-.98 0-2-1.22-2-2.5 0-.83.42-1.64 1-2.09V6.25c-1.09.53-2 1.84-2 3.25C6 11.31 7.55 13 9 13h4c1.45 0 3-1.69 3-3.5S14.5 6 13 6z\"></path></svg></a>참고자료</h3>\n<ul>\n<li><a href=\"http://seouliotcenter.tistory.com/65?category=663840\" target=\"_blank\">스프링과정1강</a> 블스(김명호 강사)</li>\n</ul>","frontmatter":{"date":"November 07, 2018","title":"스프링 1강 - 시작하기","categories":"spring"},"fields":{"slug":"/spring/2018-11-07-spring-01/"}},"prev":{"id":"59297493-0ded-5edf-a4a8-374055a23510","html":"<p><a href=\"http://seouliotcenter.tistory.com/72?category=663840\" target=\"_blank\">소스코드 다운받기</a></p>\n<h2 id=\"8-1-environment-객체\" style=\"position:relative;\"><a href=\"#8-1-environment-%EA%B0%9D%EC%B2%B4\" aria-label=\"8 1 environment 객체 permalink\" class=\"anchor before\"><svg aria-hidden=\"true\" focusable=\"false\" height=\"16\" version=\"1.1\" viewBox=\"0 0 16 16\" width=\"16\"><path fill-rule=\"evenodd\" d=\"M4 9h1v1H4c-1.5 0-3-1.69-3-3.5S2.55 3 4 3h4c1.45 0 3 1.69 3 3.5 0 1.41-.91 2.72-2 3.25V8.59c.58-.45 1-1.27 1-2.09C10 5.22 8.98 4 8 4H4c-.98 0-2 1.22-2 2.5S3 9 4 9zm9-3h-1v1h1c1 0 2 1.22 2 2.5S13.98 12 13 12H9c-.98 0-2-1.22-2-2.5 0-.83.42-1.64 1-2.09V6.25c-1.09.53-2 1.84-2 3.25C6 11.31 7.55 13 9 13h4c1.45 0 3-1.69 3-3.5S14.5 6 13 6z\"></path></svg></a>8-1 Environment 객체</h2>\n<ul>\n<li>Environment 객체를 이용해서 스프링 빈 설정</li>\n</ul>\n<p>예제를 보면 xml파일에 객체를 초기화 하지 않고있는데\nMain.java에서는 getAdminId() 등의 메서드를 사용하고 있다. 어디선가 초기화를 따로 해주고 있다는 얘기.</p>\n<p>AdminConnection 파일에 들어가보자. 지난시간에 배운 InitializingBean, DisposableBean 외에 EnvironmentAware 인터페이스가 구현되어 있다.</p>\n<ul>\n<li>EnvironmentAware\n<ul>\n<li>setEnvironment() 메서드를 오버라이딩 해야한다</li>\n<li>빈 객체가 초기화 되기도(InitializingBean) 전에 콜백함수로서 호출된다</li>\n</ul>\n</li>\n</ul>\n<h2 id=\"8-2-프로퍼티-파일을-직접-이용한-설정\" style=\"position:relative;\"><a href=\"#8-2-%ED%94%84%EB%A1%9C%ED%8D%BC%ED%8B%B0-%ED%8C%8C%EC%9D%BC%EC%9D%84-%EC%A7%81%EC%A0%91-%EC%9D%B4%EC%9A%A9%ED%95%9C-%EC%84%A4%EC%A0%95\" aria-label=\"8 2 프로퍼티 파일을 직접 이용한 설정 permalink\" class=\"anchor before\"><svg aria-hidden=\"true\" focusable=\"false\" height=\"16\" version=\"1.1\" viewBox=\"0 0 16 16\" width=\"16\"><path fill-rule=\"evenodd\" d=\"M4 9h1v1H4c-1.5 0-3-1.69-3-3.5S2.55 3 4 3h4c1.45 0 3 1.69 3 3.5 0 1.41-.91 2.72-2 3.25V8.59c.58-.45 1-1.27 1-2.09C10 5.22 8.98 4 8 4H4c-.98 0-2 1.22-2 2.5S3 9 4 9zm9-3h-1v1h1c1 0 2 1.22 2 2.5S13.98 12 13 12H9c-.98 0-2-1.22-2-2.5 0-.83.42-1.64 1-2.09V6.25c-1.09.53-2 1.84-2 3.25C6 11.31 7.55 13 9 13h4c1.45 0 3-1.69 3-3.5S14.5 6 13 6z\"></path></svg></a>8-2 프로퍼티 파일을 직접 이용한 설정</h2>\n<ul>\n<li>Environment 객체를 생성하지 않고 프로퍼티 파일을 직접 이용해서 스프링 빈을 설정할 수 있다</li>\n</ul>\n<h2 id=\"8-3-프로파일-속성을-이용한-설정\" style=\"position:relative;\"><a href=\"#8-3-%ED%94%84%EB%A1%9C%ED%8C%8C%EC%9D%BC-%EC%86%8D%EC%84%B1%EC%9D%84-%EC%9D%B4%EC%9A%A9%ED%95%9C-%EC%84%A4%EC%A0%95\" aria-label=\"8 3 프로파일 속성을 이용한 설정 permalink\" class=\"anchor before\"><svg aria-hidden=\"true\" focusable=\"false\" height=\"16\" version=\"1.1\" viewBox=\"0 0 16 16\" width=\"16\"><path fill-rule=\"evenodd\" d=\"M4 9h1v1H4c-1.5 0-3-1.69-3-3.5S2.55 3 4 3h4c1.45 0 3 1.69 3 3.5 0 1.41-.91 2.72-2 3.25V8.59c.58-.45 1-1.27 1-2.09C10 5.22 8.98 4 8 4H4c-.98 0-2 1.22-2 2.5S3 9 4 9zm9-3h-1v1h1c1 0 2 1.22 2 2.5S13.98 12 13 12H9c-.98 0-2-1.22-2-2.5 0-.83.42-1.64 1-2.09V6.25c-1.09.53-2 1.84-2 3.25C6 11.31 7.55 13 9 13h4c1.45 0 3-1.69 3-3.5S14.5 6 13 6z\"></path></svg></a>8-3 프로파일 속성을 이용한 설정</h2>\n<h3 id=\"참고자료\" style=\"position:relative;\"><a href=\"#%EC%B0%B8%EA%B3%A0%EC%9E%90%EB%A3%8C\" aria-label=\"참고자료 permalink\" class=\"anchor before\"><svg aria-hidden=\"true\" focusable=\"false\" height=\"16\" version=\"1.1\" viewBox=\"0 0 16 16\" width=\"16\"><path fill-rule=\"evenodd\" d=\"M4 9h1v1H4c-1.5 0-3-1.69-3-3.5S2.55 3 4 3h4c1.45 0 3 1.69 3 3.5 0 1.41-.91 2.72-2 3.25V8.59c.58-.45 1-1.27 1-2.09C10 5.22 8.98 4 8 4H4c-.98 0-2 1.22-2 2.5S3 9 4 9zm9-3h-1v1h1c1 0 2 1.22 2 2.5S13.98 12 13 12H9c-.98 0-2-1.22-2-2.5 0-.83.42-1.64 1-2.09V6.25c-1.09.53-2 1.84-2 3.25C6 11.31 7.55 13 9 13h4c1.45 0 3-1.69 3-3.5S14.5 6 13 6z\"></path></svg></a>참고자료</h3>\n<ul>\n<li><a href=\"http://seouliotcenter.tistory.com/72?category=663840\" target=\"_blank\">스프링과정8강</a> 블스(김명호 강사)</li>\n</ul>","frontmatter":{"date":"November 08, 2018","title":"스프링 8강 - 외부파일을 이용한 스프링 빈 설정","categories":"spring"},"fields":{"slug":"/spring/2018-11-08-spring-08/"}},"site":{"siteMetadata":{"siteUrl":"https://jonny-cho.github.io","comments":{"utterances":{"repo":""}}}}},"pageContext":{"slug":"/spring/2018-11-08-spring-07/","nextSlug":"/spring/2018-11-07-spring-01/","prevSlug":"/spring/2018-11-08-spring-08/"}},"staticQueryHashes":["1073350324","1956554647","2938748437"]}